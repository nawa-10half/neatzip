+/* NeatZip PATCH: 次に開く AES エントリ用に、並列phaseで導出済みの salt+鍵を渡す。
+   mz_zip_entry_write_open の直前に呼ぶと、その1エントリだけ PBKDF2 を省いて暗号化する。 */
+int32_t mz_zip_set_aes_key(void *handle, const uint8_t *salt, uint16_t salt_length, const uint8_t *kbuf,
+                           uint16_t kbuf_length) {
+    mz_zip *zip = (mz_zip *)handle;
+    if (!zip || !salt || !kbuf)
+        return MZ_PARAM_ERROR;
+    if (salt_length > sizeof(zip->aes_pending_salt) || kbuf_length > sizeof(zip->aes_pending_kbuf))
+        return MZ_PARAM_ERROR;
+    memcpy(zip->aes_pending_salt, salt, salt_length);
+    zip->aes_pending_salt_length = salt_length;
+    memcpy(zip->aes_pending_kbuf, kbuf, kbuf_length);
+    zip->aes_pending_kbuf_length = kbuf_length;
+    zip->aes_key_pending = 1;
+    return MZ_OK;
+}
